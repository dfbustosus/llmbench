{
	"name": "@llmbench/ui",
	"version": "0.1.3",
	"description": "UI component library for LLMBench dashboard",
	"type": "module",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/dfbustosus/llmbench.git",
		"directory": "packages/ui"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist",
		"src/globals.css"
	],
	"exports": {
		".": {
