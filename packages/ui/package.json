			"import": "./dist/index.js"
		},
		"./globals.css": "./src/globals.css"
	},
	"scripts": {
		"build": "tsc",
		"clean": "rm -rf dist",
		"prepublishOnly": "pnpm run build"
	},
	"dependencies": {
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.3.1"
	},
	"devDependencies": {
		"@types/react": "^19.1.8",
		"react": "^19.1.0",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"react": "^19.0.0"
	}
}
