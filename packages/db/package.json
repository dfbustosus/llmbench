{
	"name": "@llmbench/db",
	"version": "1.0.4",
	"description": "SQLite database layer for LLMBench",
	"type": "module",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/dfbustosus/llmbench.git",
		"directory": "packages/db"
	},
	"bugs": {
		"url": "https://github.com/dfbustosus/llmbench/issues"
	},
	"homepage": "https://github.com/dfbustosus/llmbench#readme",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist/migrations",
		"dist/repositories",
		"dist/schema",
		"dist/client.*",
		"dist/constants.*",
		"dist/index.*"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"clean": "rm -rf dist",
		"prepublishOnly": "pnpm run build"
	},
	"dependencies": {
		"@llmbench/types": "workspace:*",
		"better-sqlite3": "^11.9.1",
		"drizzle-orm": "^0.45.2",
		"nanoid": "^5.1.11"
	},
	"devDependencies": {
		"@types/better-sqlite3": "7.6.13",
		"drizzle-kit": "^0.31.10",
		"typescript": "^5.9.3",
		"vitest": "^4.1.9"
	}
}
