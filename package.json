{
  "name": "llmbench",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "biome check packages/*/src apps/*/src",
    "lint:fix": "biome check --write packages/*/src apps/*/src",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "tsx": "^4.22.1",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ],
    "overrides": {
      "picomatch": ">=4.0.4"
    }
  }
}
